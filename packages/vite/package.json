{
  "name": "@aylith/inspekt-vite",
  "version": "0.2.0",
  "description": "Inspekt Vite plugin — injects source location attributes at build time",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./webpack": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./rspack": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./esbuild": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./rolldown": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aylith/inspekt-core": "*",
    "@aylith/inspekt-cli": "*",
    "@code-inspector/core": "^2.0.4",
    "unplugin": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "vite": "^8.1.5",
    "@swc/core": "^1.15.46",
    "@types/node": "^26.1.1"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
