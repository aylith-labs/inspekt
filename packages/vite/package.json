{
  "name": "@devlens/vite",
  "version": "0.1.0",
  "description": "DevLens Vite plugin — injects source location attributes at build time",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devlens/core": "workspace:*",
    "@devlens/cli": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vite": "^6.0.0",
    "unplugin": "^2.2.0",
    "magic-string": "^0.30.0",
    "@swc/core": "^1.10.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "license": "MIT"
}
