{
  "name": "@aylith/inspekt-vite",
  "version": "0.2.0",
  "description": "Inspekt Vite plugin — injects source location attributes at build time",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./webpack": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./rspack": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./esbuild": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    },
    "./rolldown": {
      "import": "./dist/unplugin.js",
      "require": "./dist/unplugin.cjs",
      "types": "./dist/unplugin.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aylith/inspekt-core": "*",
    "@aylith/inspekt-cli": "*",
    "@code-inspector/core": "^1.5.1",
    "unplugin": "^2.2.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0",
    "vite": "^6.0.0",
    "@swc/core": "^1.10.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "license": "MIT"
}
