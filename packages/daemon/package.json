{
  "name": "@aylith/inspekt-daemon",
  "version": "0.1.0",
  "description": "Inspekt daemon — localhost HTTP server with grab queue for agent integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "inspekt-daemon": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./queue": {
      "import": "./dist/queue.js",
      "types": "./dist/queue.d.ts"
    },
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aylith/inspekt-cli": "*",
    "hono": "^4.12.31",
    "@hono/node-server": "^2.0.11",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "@types/node": "^26.1.1",
    "@types/proper-lockfile": "^4.1.4"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
