{
  "name": "@aylith/inspekt-bundlers",
  "version": "0.1.0",
  "description": "Inspekt plugins for Webpack, Rspack, esbuild, and Rollup — injects source location attributes at build time",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aylith/inspekt-vite": "*"
  },
  "peerDependencies": {
    "webpack": ">=5.0.0",
    "@rspack/core": ">=0.5.0",
    "esbuild": ">=0.17.0"
  },
  "peerDependenciesMeta": {
    "webpack": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
