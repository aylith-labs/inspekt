{
  "name": "@aylith/inspekt-core",
  "version": "0.4.0",
  "description": "Inspekt runtime — overlay, popover, tree panel, highlighting",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@jridgewell/trace-mapping": "^0.3.31",
    "bippy": "^0.5.39",
    "prismjs": "^1.30.0",
    "react-grab": "^0.1.33"
  },
  "devDependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.0",
    "@types/chrome": "^0.0.287",
    "@types/prismjs": "^1.26.6",
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0"
  },
  "sideEffects": false,
  "license": "MIT"
}
