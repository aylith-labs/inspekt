{
  "name": "@aylith/inspekt-core",
  "version": "0.4.0",
  "description": "Inspekt runtime — overlay, popover, tree panel, highlighting",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --noEmit false --declaration --emitDeclarationOnly --outDir dist --rootDir src",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "@jridgewell/trace-mapping": "^0.3.31",
    "bippy": "^0.6.0",
    "prismjs": "^1.30.0",
    "react-grab": "^0.1.48"
  },
  "devDependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@types/chrome": "^0.2.2",
    "@types/prismjs": "^1.26.6",
    "happy-dom": "^20.11.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
